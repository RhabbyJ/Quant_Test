# ==========================================
# Kalshi PM Market Making MVP Configuration
# ==========================================

# 1. Kalshi Environment & Mode
# "real" to stream live data (requires API keys below)
# "synthetic" to generate fake ping-pong trades
# "auto" falls back to synthetic if keys are missing
KALSHI_MODE=auto

# "demo" or "prod" to target the correct Kalshi API endpoints
KALSHI_ENV=demo

# Auto-discover BTC ladders each run (recommended)
# If discovery fails, KALSHI_TICKERS is used as fallback.
KALSHI_DISCOVER_TICKERS=true
KALSHI_DISCOVERY_SERIES=KXBTC
KALSHI_DISCOVERY_COUNT=3
KALSHI_DISCOVERY_MIN_CLOSE_MIN=30
KALSHI_DISCOVERY_MAX_CLOSE_MIN=180
# Optional: force a discovery reference spot; otherwise MOCK_SPOT_START is used.
# KALSHI_DISCOVERY_SPOT=70000

# Comma-separated fallback tickers (used only if discovery fails or disabled)
KALSHI_TICKERS=""

# 2. Kalshi API Credentials (Required for KALSHI_MODE=real)
# Get these from the Kalshi Developer Portal
# KALSHI_API_KEY_ID="your-api-key-id-here"
# KALSHI_PRIVATE_KEY_PATH="./kalshi.pem"
# KALSHI_DISABLE_PROXY=true

# 3. Mock Spot Engine (BTC External Feed)
# ENABLE_MOCK_SPOT=true
# MOCK_SPOT_START=110000
# MOCK_SPOT_INTERVAL_MS=1000

# 4. Strategy / Risk guardrails
# WARMUP_SAMPLES=300
# KALSHI_HEARTBEAT_MS=30000
# HEALTH_STALE_SEC defaults to ceil(KALSHI_HEARTBEAT_MS / 1000) if unset.
# HEALTH_STALE_SEC=30
# VOL_HALF_LIFE_SEC=300
# Optional legacy override: fixed EWMA lambda (if set, half-life is ignored)
# EWMA_DECAY_FACTOR=0.94
# RISK_AUTO_RECOVER_MS=10000
# MIN_QUOTE_TTE_MS=180000
# EXCLUDE_LAST_MINUTES=3
# PROFIT_KPI_MIN_FILLS=50

# Quoter / spread controls
# VOL_SPREAD_MULT=5.0
# QUOTE_SIZE_BASE=10
# QUOTE_SIZE_INIT=10
# QUOTE_SIZE_MIN=1
# QUOTE_SIZE_MAX=25

# Fee-adjusted edge telemetry + spread governor
# EDGE_HORIZON_MS=10000
# EDGE_TOLERANCE_MS=2000
# EDGE_SLIPPAGE_BUFFER_CENTS=0.20
# SPREAD_GOV_WINDOW_FILLS=30
# SPREAD_GOV_MIN_FILLS=50
# SPREAD_GOV_COOLDOWN_MS=5000
# SPREAD_GOV_BOOTSTRAP_SAMPLES=300
# SPREAD_GOV_TIGHTEN_LCB_CENTS=0.20
# SPREAD_GOV_WIDEN_UCB_CENTS=0.0
# SPREAD_GOV_HYSTERESIS_CENTS=0.05
# SPREAD_GOV_TOXICITY_SPIKE=1.0
# SPREAD_GOV_TOXICITY_LOW=0.25
# SPREAD_GOV_STEP_UP=0.5
# SPREAD_GOV_STEP_DOWN=0.2
# SPREAD_GOV_SIZE_DOWN_STREAK=2
# SPREAD_GOV_SIZE_UP_STREAK=4
# SPREAD_GOV_MULT_MIN=2.0
# SPREAD_GOV_MULT_MAX=20.0

# Market quality filter (eligibility)
# MARKET_MIN_TRADES_PER_HOUR=0
# MARKET_MIN_TOP_DEPTH=5
# MARKET_MAX_BOOK_AGE_MS=20000
# MARKET_RANK_ENABLED=false
# MARKET_RANK_INTERVAL_MS=3600000
# MARKET_RANK_WINDOW_MS=3600000
# MARKET_RANK_MIN_FILLS=20
# MARKET_RANK_TOP_N=3
# MARKET_RANK_TOXICITY_WEIGHT=5.0
# MARKET_RANK_CI_WEIGHT=1.0

# Paper fill realism mode
# PAPER_REALISM_MODE=base   # off | base | pessimistic
# PAPER_REALISM_ORDER_LATENCY_MS=100
# PAPER_REALISM_CANCEL_LAG_MS=100
# PAPER_REALISM_QUEUE_HAIRCUT=0.8

# 5. Dead-market failover (re-discover + hot-rotate ladder)
# DEAD_MARKET_FAILOVER_ENABLED=true
# DEAD_MARKET_CHECK_SEC=30
# DEAD_MARKET_WINDOW_SEC=120
# DEAD_MARKET_MIN_TRADES=1
# DEAD_MARKET_COOLDOWN_SEC=120
# RESEARCH_FIXED_LADDER=false
